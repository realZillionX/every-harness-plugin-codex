{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$PLUGIN_ROOT/hooks/session-lifecycle-hook.mjs\" SessionStart",
            "statusMessage": "Initializing Every Harness mailbox"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$PLUGIN_ROOT/hooks/unread-result-hook.mjs\"",
            "statusMessage": "Checking Every Harness mailbox"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$PLUGIN_ROOT/hooks/stop-review-gate-hook.mjs\"",
            "timeout": 900
          }
        ]
      }
    ]
  }
}
